{
    "name": "waaseyaa/wayfinding",
    "description": "Wayfinding: guided, element-anchored beacons for the live UI (Phase 1: anchor registry + published catalog)",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../entity-storage"
        },
        {
            "type": "path",
            "url": "../api"
        },
        {
            "type": "path",
            "url": "../foundation"
        },
        {
            "type": "path",
            "url": "../routing"
        }
    ],
    "require": {
        "php": ">=8.5",
        "waaseyaa/api": "^0.1.0-alpha.241",
        "waaseyaa/entity": "^0.1.0-alpha.241",
        "waaseyaa/entity-storage": "^0.1.0-alpha.241",
        "waaseyaa/foundation": "^0.1.0-alpha.241",
        "waaseyaa/routing": "^0.1.0-alpha.241"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Wayfinding\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Wayfinding\\Tests\\": "tests/"
        }
    },
    "extra": {
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\Wayfinding\\WayfindingServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
